[
    {
        "label": "Run",
        "command": "$ZED_WORKTREE_ROOT/.zed/run.sh",
        "args": ["$ZED_FILE"],
        "use_new_terminal": false,
        "cwd": "$ZED_WORKTREE_ROOT"
    },
    {
        "label": "Run Python Current",
        "command": "conda run -n sage10.8 python $ZED_FILE",
        "use_new_terminal": false,
        "cwd": "$ZED_WORKTREE_ROOT"
    }
]
